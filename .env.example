# Azure OpenAI (GPT) — new modular pipeline
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-5-chat-global-01
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Azure OpenAI (legacy scripts / rank API compatibility)
AZURE_ENDPOINT=https://us-east-02-gpt-01.openai.azure.com
AZURE_API_KEY=your-azure-api-key-here

# 腾讯云 COS（仅 deploy_cos.sh 需要）
COS_SECRET_ID=
COS_SECRET_KEY=

# SMS（手机号验证码登录）
VERIFICATION_CODE_TTL_SECONDS=300
VERIFICATION_CODE_RESEND_LOCK_SECONDS=60
VERIFICATION_CODE_DAILY_LIMIT=20
SMS_DELIVERY_ENABLED=true
SMS_REGION=cn-hangzhou
SMS_ACCESS_KEY_ID=your-sms-access-key-id
SMS_ACCESS_KEY_SECRET=your-sms-access-key-secret
SMS_SIGN_NAME=your-sms-sign-name
SMS_TEMPLATE_CODE=your-sms-template-code
SMS_TEST_PHONE_NUMBERS=
SMS_TEST_CODE=123456
AUTH_DEBUG_SMS_CODE=0

# Apple Sign In
APPLE_AUDIENCE=com.flipod.mobile

